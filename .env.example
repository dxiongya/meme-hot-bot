# --- Server ---
PORT=3000
LOG_LEVEL=info

# --- Postgres (matches docker-compose) ---
DATABASE_URL=postgresql://radar:radar@localhost:5435/radar

# --- Egress proxy (set if your network blocks gmgn-cli / xapi / openrouter) ---
# Optional. Leave empty for direct egress.
HTTPS_PROXY=
HTTP_PROXY=

# --- Telegram push (scan results auto-pushed here) ---
# 1) @BotFather → /newbot → 拷贝 token
# 2) 用 scripts/get-telegram-chat-id.ts 拿 chat_id
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=<your-bot-token>
TELEGRAM_CHAT_ID=<your-chat-id>

# --- xapi key (twitter.search + web.search via action.xapi.to) ---
XAPI_API_KEY=<your-xapi-key>

# --- LLM provider — pick ONE block ---
# Option A: DeepSeek (recommended, OpenAI-compatible, 1M context, cheap)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
CHAT_LLM_MODEL=deepseek-v4-flash
FAST_LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=<your-deepseek-key>

# Option B: GLM (智谱 open.bigmodel.cn, OpenAI-compatible, CN-friendly)
# LLM_PROVIDER=glm
# LLM_MODEL=glm-4-plus
# CHAT_LLM_MODEL=glm-4-flash
# GLM_API_KEY=<your-glm-key>

# Option C: Anthropic direct
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-7
# ANTHROPIC_API_KEY=sk-ant-...

# Option D: OpenRouter
# LLM_PROVIDER=openrouter
# LLM_MODEL=x-ai/grok-4
# OPENROUTER_API_KEY=sk-or-...

# --- Meme scheduler ---
SCAN_CRON=2,17,32,47 * * * *
SCAN_CHAINS=sol,base,bsc,eth
SCAN_AUTO_START=true

# --- Brain (where scan markdown is written) ---
BRAIN_DIR=./brain
