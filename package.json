    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.14",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "playwright": "^1.59.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
